{
  "name": "minio-mcp-server",
  "version": "0.1.0",
  "description": "MCP server for MinIO/S3 — bucket management, object CRUD, presigned URLs, policies, analytics",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "minio-mcp-server": "dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ test/",
    "lint:fix": "eslint src/ test/ --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "validate": "tsc --noEmit && eslint src/ test/ && vitest run && prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "package": "pnpm pack --pack-gzip-level 9",
    "ci": "tsc --noEmit && eslint src/ test/ && vitest run --coverage && prettier --check \"src/**/*.ts\" \"test/**/*.ts\""
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "minio": "^8.0.5",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^20.17.57",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.28.0",
    "eslint-plugin-security": "^4.0.0",
    "prettier": "^3.5.3",
    "tsup": "^8.5.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.57.1",
    "vitest": "^3.2.4"
  },
  "files": ["dist/", "README.md"],
  "keywords": ["mcp", "minio", "s3", "object-storage", "devops", "infrastructure", "ai", "copilot"],
  "license": "MIT"
}
